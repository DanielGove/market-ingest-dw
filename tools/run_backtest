#!/bin/bash
# Unified backtest entrypoint for engine/determinism workflows.
#
# Modes:
#   engine       Run closed-loop engine.
#   determinism  Run replay determinism check.
#   all          Run engine -> determinism.
#
# Examples:
#   ./tools/run_backtest engine
#   WINDOW_SECONDS=120 STRATEGY=ping_pong ./tools/run_backtest all

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PY="${PY:-$ROOT_DIR/venv/bin/python}"
MODE="${1:-engine}"
if [ $# -gt 0 ]; then
  shift
fi

if [ ! -x "$PY" ]; then
  PY="python3"
fi

WINDOW_SECONDS="${WINDOW_SECONDS:-60}"
STRATEGY="${STRATEGY:-ping_pong}"
RUN_ID="${RUN_ID:-RUN1}"
OUT_DIR="${OUT_DIR:-$ROOT_DIR/out/backtest/$RUN_ID}"
SEGMENT_ID="${SEGMENT_ID:-}"
SEGMENTS_FILE="${SEGMENTS_FILE:-$ROOT_DIR/out/backtest/segments.jsonl}"

mkdir -p "$OUT_DIR"
MANIFEST_PATH="$OUT_DIR/engine-manifest.json"

print_run_context() {
  echo "mode=$MODE seconds=$WINDOW_SECONDS strategy=$STRATEGY run_id=$RUN_ID"
}

usage() {
  cat <<'EOF'
Usage:
  ./tools/run_backtest <mode> [extra-args]

Modes:
  engine       closed-loop replay (strategy + exchange splice + execution feed)
  determinism  replay same frozen window twice and compare behavioral outputs
  all          engine -> determinism

Key env vars:
  WINDOW_SECONDS, STRATEGY, RUN_ID
  OUT_DIR, PY
EOF
}

run_engine() {
  local seg_args=()
  if [ -n "$SEGMENT_ID" ]; then
    seg_args+=(--segment-id "$SEGMENT_ID" --segments-file "$SEGMENTS_FILE")
  fi
  "$PY" "$ROOT_DIR/backtest/engine.py" \
    --seconds "$WINDOW_SECONDS" \
    --strategy "$STRATEGY" \
    --run-id "$RUN_ID" \
    --manifest-path "$MANIFEST_PATH" \
    "${seg_args[@]}" \
    "$@"
}

run_determinism() {
  local seg_args=()
  if [ -n "$SEGMENT_ID" ]; then
    seg_args+=(--segment-id "$SEGMENT_ID" --segments-file "$SEGMENTS_FILE")
  fi
  "$PY" "$ROOT_DIR/tools/replay_determinism_check.py" \
    --seconds "$WINDOW_SECONDS" \
    --strategy "$STRATEGY" \
    --run-id "$RUN_ID" \
    "${seg_args[@]}" \
    "$@"
}

case "$MODE" in
  engine)
    print_run_context
    run_engine "$@"
    ;;
  determinism)
    print_run_context
    run_determinism "$@"
    ;;
  all)
    print_run_context
    run_engine
    run_determinism
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown mode: $MODE"
    usage
    exit 2
    ;;
esac

echo "Artifacts directory: $OUT_DIR"
