#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

PRODUCTS="${PRODUCTS:-BTC-USD,BTC-USDT,ETH-USD,ETH-USDT,SOL-USD,SOL-USDT,USDT-USD,USDT-USDC,XRP-USD,XRP-USDT}"
DEFAULT_BASE_PATH="$ROOT_DIR/data/coinbase-main"
if [ -d "/deepwater/data" ]; then
  DEFAULT_BASE_PATH="/deepwater/data/coinbase-advanced"
fi
BASE_PATH="${BASE_PATH:-$DEFAULT_BASE_PATH}"

PY="${PY:-$ROOT_DIR/venv/bin/python}"
if [ ! -x "$PY" ]; then
  PY="python3"
fi

LOG_DIR="$SCRIPT_DIR/logs"
PID_DIR="$SCRIPT_DIR/pids"
INGEST_SOCK="$PID_DIR/ingest.sock"
PIDFILE="$PID_DIR/ingest.pid"

mkdir -p "$LOG_DIR" "$PID_DIR" "$BASE_PATH"
cd "$ROOT_DIR"

if [ -f "$PIDFILE" ]; then
  pid="$(cat "$PIDFILE")"
  if kill -0 "$pid" 2>/dev/null; then
    echo "ingest already running pid=$pid"
    exit 1
  fi
  rm -f "$PIDFILE"
fi

echo "starting l2 ingest"
echo "==== ingest launch $(date -u +%Y-%m-%dT%H:%M:%SZ) products=$PRODUCTS base_path=$BASE_PATH ====" >> "$LOG_DIR/ingest.log"
PYTHONPATH="$ROOT_DIR" nohup "$PY" "$SCRIPT_DIR/ws_ingest_daemon.py" \
  --products "$PRODUCTS" \
  --base-path "$BASE_PATH" \
  --control-sock "$INGEST_SOCK" \
  >> "$LOG_DIR/ingest.log" 2>&1 &
echo $! > "$PIDFILE"
echo "  ingest_pid=$(cat "$PIDFILE")"

sleep 1
if ! kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "ingest failed, see $LOG_DIR/ingest.log"
  exit 1
fi
