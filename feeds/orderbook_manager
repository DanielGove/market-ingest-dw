#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

PRODUCTS="${PRODUCTS:-}"
BASE_PATH="${BASE_PATH:?BASE_PATH required}"
OB_DEPTH="${OB_DEPTH:?OB_DEPTH required}"
OB_PERIOD="${OB_PERIOD:?OB_PERIOD required}"
WARMUP_SECONDS="${WARMUP_SECONDS:-60}"
OB_PREFIX="${OB_PREFIX:-OB}"
OB_MAX_LEVELS="${OB_MAX_LEVELS:-8192}"
OB_WORKERS="${OB_WORKERS:-2}"
OB_PIN_CORES="${OB_PIN_CORES:-auto}"
PY="${PY:-python3}"

LOG_DIR="$SCRIPT_DIR/logs"
PID_DIR="$SCRIPT_DIR/pids"
mkdir -p "$LOG_DIR" "$PID_DIR"

if [ -z "$PRODUCTS" ]; then
  echo "orderbook manager: empty PRODUCTS" >&2
  exit 1
fi

# Parse products, trimming spaces around comma-separated values.
IFS=',' read -r -a raw_products <<< "$PRODUCTS"
products=()
for p in "${raw_products[@]}"; do
  p_trimmed="$(echo "$p" | sed 's/^ *//; s/ *$//')"
  if [ -n "$p_trimmed" ]; then
    products+=("$p_trimmed")
  fi
done

if [ "${#products[@]}" -eq 0 ]; then
  echo "orderbook manager: no valid products after parsing" >&2
  exit 1
fi

workers="$OB_WORKERS"
if ! [[ "$workers" =~ ^[0-9]+$ ]]; then
  workers=0
fi
if [ "$workers" -le 0 ] || [ "$workers" -gt "${#products[@]}" ]; then
  workers="${#products[@]}"
fi

expand_cpu_list() {
  local list="$1"
  local part start end c
  local out=()
  IFS=',' read -r -a parts <<< "$list"
  for part in "${parts[@]}"; do
    part="$(echo "$part" | sed 's/^ *//; s/ *$//')"
    if [ -z "$part" ]; then
      continue
    fi
    if [[ "$part" == *-* ]]; then
      start="${part%-*}"
      end="${part#*-}"
      if [[ "$start" =~ ^[0-9]+$ ]] && [[ "$end" =~ ^[0-9]+$ ]] && [ "$start" -le "$end" ]; then
        for ((c=start; c<=end; c++)); do
          out+=("$c")
        done
      fi
    elif [[ "$part" =~ ^[0-9]+$ ]]; then
      out+=("$part")
    fi
  done
  echo "${out[*]}"
}

pin_cores=()
if command -v taskset >/dev/null 2>&1; then
  requested="$OB_PIN_CORES"
  if [ -z "$requested" ] || [ "$requested" = "auto" ]; then
    affinity="$(taskset -cp $$ 2>/dev/null | awk -F': ' '{print $2}' | tail -n1)"
    available=( $(expand_cpu_list "$affinity") )
    if [ "${#available[@]}" -ge "$workers" ]; then
      start_idx=$(( ${#available[@]} - workers ))
      for ((i=start_idx; i<${#available[@]}; i++)); do
        pin_cores+=("${available[$i]}")
      done
    fi
  else
    configured=( $(expand_cpu_list "$requested") )
    if [ "${#configured[@]}" -ge "$workers" ]; then
      for ((i=0; i<workers; i++)); do
        pin_cores+=("${configured[$i]}")
      done
    else
      echo "orderbook manager: OB_PIN_CORES='$requested' has fewer cores than workers=$workers; skipping pinning"
    fi
  fi
fi

pids=()
for ((i=0; i<workers; i++)); do
  shard=()
  for ((j=i; j<${#products[@]}; j+=workers)); do
    shard+=("${products[$j]}")
  done
  if [ "${#shard[@]}" -eq 0 ]; then
    continue
  fi
  shard_csv="$(IFS=,; echo "${shard[*]}")"
  sock="$PID_DIR/orderbook_${i}.sock"
  rm -f "$sock"
  if [ "${#pin_cores[@]}" -ge "$workers" ]; then
    core="${pin_cores[$i]}"
    echo "starting orderbook worker[$i] core=$core products=$shard_csv"
    PYTHONPATH="$ROOT_DIR" taskset -c "$core" "$PY" "$SCRIPT_DIR/orderbook_daemon.py" \
      --products "$shard_csv" \
      --base-path "$BASE_PATH" \
      --depth "$OB_DEPTH" \
      --period "$OB_PERIOD" \
      --warmup-seconds "$WARMUP_SECONDS" \
      --feed-prefix "$OB_PREFIX" \
      --max-levels "$OB_MAX_LEVELS" \
      --control-sock "$sock" \
      >> "$LOG_DIR/orderbook.log" 2>&1 &
  else
    echo "starting orderbook worker[$i] products=$shard_csv"
    PYTHONPATH="$ROOT_DIR" "$PY" "$SCRIPT_DIR/orderbook_daemon.py" \
      --products "$shard_csv" \
      --base-path "$BASE_PATH" \
      --depth "$OB_DEPTH" \
      --period "$OB_PERIOD" \
      --warmup-seconds "$WARMUP_SECONDS" \
      --feed-prefix "$OB_PREFIX" \
      --max-levels "$OB_MAX_LEVELS" \
      --control-sock "$sock" \
      >> "$LOG_DIR/orderbook.log" 2>&1 &
  fi
  pids+=("$!")
done

if [ "${#pids[@]}" -eq 0 ]; then
  echo "orderbook manager: failed to start workers" >&2
  exit 1
fi

shutdown() {
  for pid in "${pids[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  wait || true
}
trap shutdown TERM INT

set +e
wait -n "${pids[@]}"
rc=$?
set -e
shutdown
exit "$rc"
