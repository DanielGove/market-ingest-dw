#!/bin/bash
# Start Coinbase data pipeline: L2 ingest + orderbook construction

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Defaults (overridable via env)
PRODUCTS="${PRODUCTS:-BTC-USD,ETH-USD,SOL-USD,XRP-USD}"
BASE_PATH="${BASE_PATH:-$ROOT_DIR/data/coinbase-main}"
OB_DEPTH="${OB_DEPTH:-200}"
OB_PERIOD="${OB_PERIOD:-50}"

VENV="$ROOT_DIR/venv/bin/python"
LOG_DIR="$SCRIPT_DIR/logs"
HEALTH_LOG_DIR="$LOG_DIR/health"
RESOURCE_LOG_DIR="$LOG_DIR/resource"
PID_DIR="$SCRIPT_DIR/pids"
INGEST_SOCK="$PID_DIR/ingest.sock"
ORDERBOOK_SOCK="$PID_DIR/orderbook.sock"
HEALTH_PIDFILE="$PID_DIR/health.pid"
RESOURCE_PIDFILE="$PID_DIR/resource.pid"

mkdir -p "$LOG_DIR" "$HEALTH_LOG_DIR" "$RESOURCE_LOG_DIR" "$PID_DIR"
cd "$ROOT_DIR"
mkdir -p "$BASE_PATH"
mkdir -p "$BASE_PATH"

echo "🚀 Starting Coinbase data pipeline"
echo "📁 Base path: $BASE_PATH"
echo "📊 Products: $PRODUCTS"
FREQ_HZ=$(echo "scale=1; 1000 / $OB_PERIOD" | bc)
echo "📈 Orderbook: OB${OB_DEPTH}${OB_PERIOD} @ ${OB_PERIOD}ms (${FREQ_HZ}Hz)"
echo ""

# Start L2 WebSocket ingest
echo "▶️  Starting L2 ingest..."
PYTHONPATH="$ROOT_DIR" nohup $VENV "$SCRIPT_DIR/ws_ingest_daemon.py" \
    --products "$PRODUCTS" \
    --base-path "$BASE_PATH" \
    --control-sock "$INGEST_SOCK" \
    > "$LOG_DIR/ingest.log" 2>&1 &
echo $! > "$PID_DIR/ingest.pid"
echo "   ✅ L2 ingest started (PID: $(cat "$PID_DIR/ingest.pid"))"

# Wait for feeds to be created
echo "⏳ Waiting 1s for L2 feeds..."
sleep 1

if ! kill -0 $(cat "$PID_DIR/ingest.pid") 2>/dev/null; then
    echo "❌ L2 ingest failed! Check $LOG_DIR/ingest.log"
    exit 1
fi

# Start orderbook daemon
echo "▶️  Starting orderbook daemon..."
PYTHONPATH="$ROOT_DIR" nohup $VENV "$SCRIPT_DIR/orderbook_daemon.py" \
    --products "$PRODUCTS" \
    --base-path "$BASE_PATH" \
    --depth "$OB_DEPTH" \
    --period "$OB_PERIOD" \
    --control-sock "$ORDERBOOK_SOCK" \
    > "$LOG_DIR/orderbook.log" 2>&1 &
echo $! > "$PID_DIR/orderbook.pid"
echo "   ✅ Orderbook daemon started (PID: $(cat "$PID_DIR/orderbook.pid"))"

# Start health monitor (60s cadence, 60s window)
echo "▶️  Starting health monitor..."
PRODUCTS="$PRODUCTS" BASE_PATH="$BASE_PATH" LOG_DIR="$HEALTH_LOG_DIR" \
INTERVAL=60 WINDOW_SEC=60 RETAIN_DAYS=10 nohup "$ROOT_DIR/tools/health_check" \
    > "$HEALTH_LOG_DIR/health-latest.log" 2>&1 &
echo $! > "$HEALTH_PIDFILE"
echo "   ✅ Health monitor started (PID: $(cat $HEALTH_PIDFILE))"

# Start resource monitor (60s cadence)
echo "▶️  Starting resource monitor..."
BASE_PATH="$BASE_PATH" LOG_DIR="$RESOURCE_LOG_DIR" PID_DIR="$PID_DIR" INTERVAL=60 RETAIN_DAYS=10 nohup "$ROOT_DIR/tools/resource_monitor" \
    > "$RESOURCE_LOG_DIR/resource-latest.log" 2>&1 &
echo $! > "$RESOURCE_PIDFILE"
echo "   ✅ Resource monitor started (PID: $(cat $RESOURCE_PIDFILE))"

echo ""
echo "✅ Pipeline running!"
echo ""
echo "📊 Monitor:"
echo "   tail -f feeds/logs/ingest.log"
echo "   tail -f feeds/logs/orderbook.log"
echo "   tail -f feeds/logs/health/health-latest.log"
echo "   tail -f feeds/logs/resource/resource-latest.log"
echo ""
echo "🛑 Stop:"
echo "   ./feeds/stop"
