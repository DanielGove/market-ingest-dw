#!/bin/bash
# Start a single orderbook daemon with its own socket/log/pid.
# Usage: ./feeds/start_ob <depth> <period_ms> <products> [base_path] [feed_prefix] [max_levels]
# Example: ./feeds/start_ob 200 50 "BTC-USD,XRP-USD,ETH-USD" /deepwater/data/coinbase-advanced OBC 8192

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENUE_KEY="${DW_VENUE_KEY:-${DW_VENUE:-coinbase}}"

if [ "$VENUE_KEY" = "kraken" ]; then
  DEFAULT_BASE_PATH="data/kraken-main"
  DEFAULT_DEEPWATER_BASE="/deepwater/data/kraken-spot"
  DEFAULT_L2_FEED_PREFIX="KR-L2"
else
  DEFAULT_BASE_PATH="data/coinbase-main"
  DEFAULT_DEEPWATER_BASE="/deepwater/data/coinbase-advanced"
  DEFAULT_L2_FEED_PREFIX="CB-L2"
fi

DEPTH="$1"
PERIOD="$2"
PRODUCTS="$3"
if [ -d "/deepwater/data" ]; then
  DEFAULT_BASE_PATH="$DEFAULT_DEEPWATER_BASE"
fi
BASE_PATH="${4:-$DEFAULT_BASE_PATH}"
OB_PREFIX="${OB_PREFIX:-${5:-OB}}"
OB_MAX_LEVELS="${OB_MAX_LEVELS:-${6:-8192}}"
WARMUP_SECONDS="${WARMUP_SECONDS:-60}"
L2_FEED_PREFIX="${L2_FEED_PREFIX:-$DEFAULT_L2_FEED_PREFIX}"
VENV="$ROOT_DIR/venv/bin/python"

if [ -z "$DEPTH" ] || [ -z "$PERIOD" ] || [ -z "$PRODUCTS" ]; then
  echo "Usage: $0 <depth> <period_ms> <products> [base_path] [feed_prefix] [max_levels]"
  exit 1
fi

LOG_DIR="$SCRIPT_DIR/logs"
PID_DIR="$SCRIPT_DIR/pids"
mkdir -p "$LOG_DIR" "$PID_DIR"

SOCK="$PID_DIR/orderbook_${DEPTH}_${PERIOD}.sock"
LOG="$LOG_DIR/orderbook_${DEPTH}_${PERIOD}.log"
PIDFILE="$PID_DIR/orderbook_${DEPTH}_${PERIOD}.pid"

echo "▶️  Starting orderbook daemon ${OB_PREFIX}${DEPTH}${PERIOD} for ${PRODUCTS}..."
nohup $VENV "$SCRIPT_DIR/orderbook_daemon.py" \
  --products "$PRODUCTS" \
  --base-path "$BASE_PATH" \
  --depth "$DEPTH" \
  --period "$PERIOD" \
  --warmup-seconds "$WARMUP_SECONDS" \
  --feed-prefix "$OB_PREFIX" \
  --l2-feed-prefix "$L2_FEED_PREFIX" \
  --max-levels "$OB_MAX_LEVELS" \
  --control-sock "$SOCK" \
  > "$LOG" 2>&1 &

echo $! > "$PIDFILE"
echo "   ✅ PID: $(cat $PIDFILE)  sock: $SOCK  log: $LOG"
