#!/usr/bin/env python3
"""Unified control plane for feed services (human + agent friendly)."""
from __future__ import annotations

import argparse
import glob
import json
import os
import shlex
import socket
import subprocess
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any


SCRIPT_PATH = Path(__file__).resolve()
FEEDS_DIR = SCRIPT_PATH.parent
ROOT_DIR = FEEDS_DIR.parent
PIDS_DIR = FEEDS_DIR / "pids"


@dataclass
class Proc:
    pid: int
    args: str


def _run(cmd: list[str], env: dict[str, str] | None = None, check: bool = False) -> subprocess.CompletedProcess[str]:
    merged_env = os.environ.copy()
    if env:
        merged_env.update({k: str(v) for k, v in env.items() if v is not None})
    cp = subprocess.run(
        cmd,
        cwd=str(ROOT_DIR),
        env=merged_env,
        text=True,
        capture_output=True,
    )
    if check and cp.returncode != 0:
        raise RuntimeError(f"command failed: {' '.join(cmd)} rc={cp.returncode} stderr={cp.stderr.strip()}")
    return cp


def _script(name: str, args: list[str] | None = None, env: dict[str, str] | None = None) -> dict[str, Any]:
    args = args or []
    cmd = [str(FEEDS_DIR / name)] + args
    cp = _run(cmd, env=env)
    return {
        "cmd": cmd,
        "rc": cp.returncode,
        "stdout": cp.stdout.strip(),
        "stderr": cp.stderr.strip(),
    }


def _ps() -> list[Proc]:
    cp = _run(["ps", "-eo", "pid,args"], check=True)
    out: list[Proc] = []
    for line in cp.stdout.splitlines()[1:]:
        line = line.strip()
        if not line:
            continue
        parts = line.split(maxsplit=1)
        if len(parts) != 2:
            continue
        try:
            pid = int(parts[0])
        except ValueError:
            continue
        out.append(Proc(pid=pid, args=parts[1]))
    return out


def _find_procs(procs: list[Proc], needle: str) -> list[Proc]:
    return [p for p in procs if needle in p.args]


def _find_local_procs(procs: list[Proc], rel_path: str) -> list[Proc]:
    abs_path = str((ROOT_DIR / rel_path).resolve())
    return [p for p in procs if abs_path in p.args]


def _alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def _read_pidfile(path: Path) -> int | None:
    try:
        data = path.read_text(encoding="utf-8").strip()
        return int(data)
    except Exception:
        return None


def _write_pidfile(path: Path, pid: int) -> None:
    path.write_text(f"{pid}\n", encoding="utf-8")


def _terminate_pid(pid: int, grace_s: float = 1.0) -> bool:
    """Best-effort terminate, returning True when process is gone."""
    try:
        os.kill(pid, 15)
    except OSError:
        return True
    deadline = time.time() + grace_s
    while time.time() < deadline:
        if not _alive(pid):
            return True
        time.sleep(0.05)
    try:
        os.kill(pid, 9)
    except OSError:
        return True
    return not _alive(pid)


def _pick_keep_pid(live_pids: list[int], pidfile_pid: int | None) -> int | None:
    if not live_pids:
        return None
    if pidfile_pid is not None and pidfile_pid in live_pids:
        return pidfile_pid
    return min(live_pids)


def _taskset(pid: int) -> str | None:
    cp = _run(["taskset", "-cp", str(pid)])
    if cp.returncode != 0:
        return None
    line = (cp.stdout.strip() or cp.stderr.strip())
    if ":" in line:
        return line.split(":", 1)[1].strip()
    return line or None


def _connect_cmd(sock_path: Path, cmd: str, timeout: float = 0.25) -> str | None:
    if not sock_path.exists():
        return None
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        s.settimeout(timeout)
        s.connect(str(sock_path))
        s.sendall((cmd + "\n").encode("ascii", "ignore"))
        data = s.recv(4096)
        return data.decode("ascii", "ignore").strip()
    except Exception:
        return None
    finally:
        try:
            s.close()
        except Exception:
            pass


def _parse_csv_products(raw: str | None) -> list[str]:
    if not raw:
        return []
    out = []
    for item in raw.split(","):
        x = item.strip()
        if x:
            out.append(x)
    return out


def _parse_options(args_str: str) -> dict[str, str]:
    opts: dict[str, str] = {}
    try:
        toks = shlex.split(args_str)
    except Exception:
        toks = args_str.split()
    i = 0
    while i < len(toks):
        t = toks[i]
        if t.startswith("--"):
            key = t[2:]
            if i + 1 < len(toks) and not toks[i + 1].startswith("--"):
                opts[key] = toks[i + 1]
                i += 2
                continue
            opts[key] = ""
        i += 1
    return opts


def _build_status() -> dict[str, Any]:
    procs = _ps()
    ingest_path = str((FEEDS_DIR / "ws_ingest_daemon.py").resolve())
    supervise_path = str((FEEDS_DIR / "supervise").resolve())
    ingest_procs = _find_local_procs(procs, "feeds/ws_ingest_daemon.py")
    sup_procs = _find_local_procs(procs, "feeds/supervise")
    ob_mgr_procs = _find_local_procs(procs, "feeds/orderbook_manager")
    ob_worker_procs = _find_local_procs(procs, "feeds/orderbook_daemon.py")

    ingest_sock = PIDS_DIR / "ingest.sock"
    ingest_raw = _connect_cmd(ingest_sock, "LIST")
    ingest_socket_healthy = ingest_raw is not None
    ingest_products = _parse_csv_products(ingest_raw)

    orderbook_socks = [Path(p) for p in sorted(glob.glob(str(PIDS_DIR / "orderbook*.sock")))]
    ob_products: set[str] = set()
    ob_sock_health: dict[str, bool] = {}
    for sp in orderbook_socks:
        resp = _connect_cmd(sp, "LIST")
        healthy = resp is not None
        ob_sock_health[str(sp)] = healthy
        if healthy:
            ob_products.update(_parse_csv_products(resp))

    def _svc_state(name: str, proc_list: list[Proc], match_substr: str) -> dict[str, Any]:
        pidfile = PIDS_DIR / f"{name}.pid"
        pidfile_pid = _read_pidfile(pidfile)
        pidfile_matches = False
        if pidfile_pid is not None and _alive(pidfile_pid):
            for p in proc_list:
                if p.pid == pidfile_pid and match_substr in p.args:
                    pidfile_matches = True
                    break
        return {
            "up": len(proc_list) > 0,
            "live_pids": [p.pid for p in proc_list],
            "count": len(proc_list),
            "pidfile": str(pidfile),
            "pidfile_pid": pidfile_pid,
            "pidfile_matches": pidfile_matches,
        }

    ingest = _svc_state("ingest", ingest_procs, ingest_path)
    supervise = _svc_state("supervise", sup_procs, supervise_path)

    orderbook_pidfile = PIDS_DIR / "orderbook.pid"
    orderbook_pidfile_pid = _read_pidfile(orderbook_pidfile)
    orderbook_pidfile_matches = False
    mode = "down"
    if ob_mgr_procs:
        mode = "manager"
    elif ob_worker_procs:
        mode = "single"
    if orderbook_pidfile_pid is not None and _alive(orderbook_pidfile_pid):
        live_ob_pids = {p.pid for p in ob_mgr_procs} | {p.pid for p in ob_worker_procs}
        orderbook_pidfile_matches = orderbook_pidfile_pid in live_ob_pids

    worker_configs = []
    for p in ob_worker_procs:
        opts = _parse_options(p.args)
        worker_configs.append(
            {
                "pid": p.pid,
                "products": _parse_csv_products(opts.get("products")),
                "depth": opts.get("depth"),
                "period": opts.get("period"),
                "warmup_seconds": opts.get("warmup-seconds"),
                "feed_prefix": opts.get("feed-prefix"),
                "max_levels": opts.get("max-levels"),
                "control_sock": opts.get("control-sock"),
                "affinity": _taskset(p.pid),
            }
        )

    anomalies: list[str] = []
    if ingest["count"] > 1:
        anomalies.append("duplicate ingest processes")
    if supervise["count"] > 1:
        anomalies.append("duplicate supervise processes")
    if len(ob_mgr_procs) > 1:
        anomalies.append("duplicate orderbook managers")
    if mode == "manager" and not ob_worker_procs:
        anomalies.append("orderbook manager running without workers")
    if ingest["up"] and not ingest["pidfile_matches"]:
        anomalies.append("ingest pidfile mismatch")
    if supervise["up"] and not supervise["pidfile_matches"]:
        anomalies.append("supervise pidfile mismatch")
    if mode != "down" and not orderbook_pidfile_matches:
        anomalies.append("orderbook pidfile mismatch")
    if ingest["up"] and not ingest_socket_healthy:
        anomalies.append("ingest socket unresponsive")
    if mode != "down" and (not ob_sock_health or not all(ob_sock_health.values())):
        anomalies.append("orderbook socket unresponsive")

    pipeline_up = mode != "down" and ingest["up"]
    control_plane_up = supervise["up"]
    healthy = pipeline_up and control_plane_up and not anomalies

    return {
        "ts_unix": int(time.time()),
        "root_dir": str(ROOT_DIR),
        "services": {
            "ingest": {
                **ingest,
                "socket": str(ingest_sock),
                "socket_healthy": ingest_socket_healthy,
                "products": ingest_products,
            },
            "orderbook": {
                "up": mode != "down",
                "mode": mode,
                "manager_pids": [p.pid for p in ob_mgr_procs],
                "worker_pids": [p.pid for p in ob_worker_procs],
                "worker_count": len(ob_worker_procs),
                "pidfile": str(orderbook_pidfile),
                "pidfile_pid": orderbook_pidfile_pid,
                "pidfile_matches": orderbook_pidfile_matches,
                "products": sorted(ob_products),
                "sockets": {str(k): v for k, v in ob_sock_health.items()},
                "workers": worker_configs,
            },
            "supervise": supervise,
        },
        "anomalies": anomalies,
        "pipeline_up": pipeline_up,
        "control_plane_up": control_plane_up,
        "healthy": healthy,
    }


def _apply_env_from_args(args: argparse.Namespace) -> dict[str, str]:
    env: dict[str, str] = {}
    mapping = {
        "products": "PRODUCTS",
        "base_path": "BASE_PATH",
        "python": "PY",
        "workers": "OB_WORKERS",
        "pin_cores": "OB_PIN_CORES",
        "ob_depth": "OB_DEPTH",
        "ob_period": "OB_PERIOD",
        "warmup_seconds": "WARMUP_SECONDS",
        "ob_prefix": "OB_PREFIX",
        "ob_max_levels": "OB_MAX_LEVELS",
    }
    for a, e in mapping.items():
        v = getattr(args, a, None)
        if v is not None:
            env[e] = str(v)
    return env


def _reconcile(aggressive: bool = False) -> dict[str, Any]:
    actions: list[dict[str, Any]] = []
    st = _build_status()

    svc_map = {
        "ingest": st["services"]["ingest"],
        "supervise": st["services"]["supervise"],
        "orderbook": st["services"]["orderbook"],
    }

    # pidfile cleanup/repair
    for name, info in svc_map.items():
        pidfile = Path(info["pidfile"])
        pidfile_pid = info.get("pidfile_pid")
        if name in ("ingest", "supervise"):
            live_pids = info.get("live_pids", [])
        else:
            live_pids = info.get("manager_pids", [])
            if not live_pids:
                live_pids = info.get("worker_pids", [])

        if pidfile_pid is not None and pidfile_pid not in live_pids and not _alive(pidfile_pid):
            try:
                pidfile.unlink(missing_ok=True)
                actions.append({"kind": "pidfile_remove", "service": name, "pid": pidfile_pid})
            except Exception as exc:
                actions.append({"kind": "error", "service": name, "error": str(exc)})

        if (pidfile_pid is None or pidfile_pid not in live_pids) and len(live_pids) == 1:
            try:
                _write_pidfile(pidfile, int(live_pids[0]))
                actions.append({"kind": "pidfile_write", "service": name, "pid": int(live_pids[0])})
            except Exception as exc:
                actions.append({"kind": "error", "service": name, "error": str(exc)})

    # stale sockets cleanup (only when owning service is down)
    ingest_sock = Path(st["services"]["ingest"]["socket"])
    if ingest_sock.exists() and not st["services"]["ingest"]["up"]:
        try:
            ingest_sock.unlink(missing_ok=True)
            actions.append({"kind": "socket_remove", "socket": str(ingest_sock)})
        except Exception as exc:
            actions.append({"kind": "error", "socket": str(ingest_sock), "error": str(exc)})

    ob = st["services"]["orderbook"]
    if not ob["up"]:
        for s in ob["sockets"].keys():
            sp = Path(s)
            if sp.exists():
                try:
                    sp.unlink(missing_ok=True)
                    actions.append({"kind": "socket_remove", "socket": s})
                except Exception as exc:
                    actions.append({"kind": "error", "socket": s, "error": str(exc)})

    # optional aggressive duplicate cleanup
    if aggressive:
        if st["services"]["ingest"]["count"] > 1:
            keep = _pick_keep_pid(
                st["services"]["ingest"]["live_pids"],
                st["services"]["ingest"].get("pidfile_pid"),
            )
            for pid in st["services"]["ingest"]["live_pids"]:
                if pid == keep:
                    continue
                gone = _terminate_pid(pid)
                actions.append(
                    {"kind": "kill_duplicate", "service": "ingest", "pid": pid, "keep": keep, "gone": gone}
                )
        if st["services"]["supervise"]["count"] > 1:
            keep = _pick_keep_pid(
                st["services"]["supervise"]["live_pids"],
                st["services"]["supervise"].get("pidfile_pid"),
            )
            for pid in st["services"]["supervise"]["live_pids"]:
                if pid == keep:
                    continue
                gone = _terminate_pid(pid)
                actions.append(
                    {"kind": "kill_duplicate", "service": "supervise", "pid": pid, "keep": keep, "gone": gone}
                )
        if len(st["services"]["orderbook"]["manager_pids"]) > 1:
            keep = _pick_keep_pid(
                st["services"]["orderbook"]["manager_pids"],
                st["services"]["orderbook"].get("pidfile_pid"),
            )
            for pid in st["services"]["orderbook"]["manager_pids"]:
                if pid == keep:
                    continue
                gone = _terminate_pid(pid)
                actions.append(
                    {"kind": "kill_duplicate", "service": "orderbook_manager", "pid": pid, "keep": keep, "gone": gone}
                )

    return {"actions": actions, "status": _build_status()}


def _ensure(args: argparse.Namespace) -> dict[str, Any]:
    actions: list[dict[str, Any]] = []

    if args.reconcile:
        rec = _reconcile(aggressive=args.aggressive)
        actions.extend(rec["actions"])

    env = _apply_env_from_args(args)
    st = _build_status()

    # supervise
    if args.supervise == "up" and not st["services"]["supervise"]["up"]:
        if not args.dry_run:
            actions.append({"kind": "exec", "result": _script("start_24x7", env=env)})
        else:
            actions.append({"kind": "dry_run", "cmd": ["feeds/start_24x7"]})
    elif args.supervise == "down" and st["services"]["supervise"]["up"]:
        if not args.dry_run:
            actions.append({"kind": "exec", "result": _script("stop", ["supervise"], env=env)})
        else:
            actions.append({"kind": "dry_run", "cmd": ["feeds/stop", "supervise"]})

    st = _build_status()

    # ingest
    if args.ingest == "up" and not st["services"]["ingest"]["up"]:
        if not args.dry_run:
            actions.append({"kind": "exec", "result": _script("start_ingest", env=env)})
        else:
            actions.append({"kind": "dry_run", "cmd": ["feeds/start_ingest"]})
    elif args.ingest == "down" and st["services"]["ingest"]["up"]:
        if not args.dry_run:
            actions.append({"kind": "exec", "result": _script("stop", ["ingest"], env=env)})
        else:
            actions.append({"kind": "dry_run", "cmd": ["feeds/stop", "ingest"]})

    st = _build_status()

    # orderbook
    ob = st["services"]["orderbook"]
    desired_workers = args.workers
    need_restart = False
    restart_reasons: list[str] = []

    if args.orderbook == "down":
        if ob["up"]:
            if not args.dry_run:
                actions.append({"kind": "exec", "result": _script("stop", ["orderbook"], env=env)})
            else:
                actions.append({"kind": "dry_run", "cmd": ["feeds/stop", "orderbook"]})
    elif args.orderbook == "up":
        if not ob["up"]:
            need_restart = True
            restart_reasons.append("orderbook down")
        if desired_workers is not None and ob["up"] and ob["worker_count"] != int(desired_workers):
            need_restart = True
            restart_reasons.append(f"worker_count {ob['worker_count']} != {int(desired_workers)}")
        if args.pin_cores is not None and ob["up"]:
            # if any worker affinity differs from desired pin set, restart
            desired = [x.strip() for x in str(args.pin_cores).split(",") if x.strip()]
            if desired and args.pin_cores != "auto":
                got = [w.get("affinity") for w in ob.get("workers", [])]
                if len(got) >= len(desired):
                    got = got[: len(desired)]
                if got != desired[: len(got)]:
                    need_restart = True
                    restart_reasons.append(f"affinity {got} != {desired[: len(got)]}")

        if ob["up"] and ob.get("workers"):
            sample = ob["workers"][0]

            def _drift(field: str, arg_name: str) -> None:
                nonlocal need_restart
                desired_value = getattr(args, arg_name, None)
                if desired_value is None:
                    return
                current = sample.get(field)
                if current is None or str(current) != str(desired_value):
                    need_restart = True
                    restart_reasons.append(f"{field} {current} != {desired_value}")

            _drift("depth", "ob_depth")
            _drift("period", "ob_period")
            _drift("warmup_seconds", "warmup_seconds")
            _drift("feed_prefix", "ob_prefix")
            _drift("max_levels", "ob_max_levels")

        desired_products: list[str] = []
        if args.products:
            desired_products = sorted(_parse_csv_products(args.products))
        elif st["services"]["ingest"]["up"]:
            desired_products = sorted(st["services"]["ingest"].get("products", []))
        current_products = sorted(ob.get("products", []))
        if desired_products and current_products != desired_products:
            need_restart = True
            restart_reasons.append("product set drift")

        if need_restart:
            if not args.dry_run:
                if st["services"]["ingest"]["up"]:
                    actions.append(
                        {
                            "kind": "exec",
                            "reason": restart_reasons,
                            "result": _script("restart_orderbook", env=env),
                        }
                    )
                else:
                    actions.append(
                        {
                            "kind": "exec",
                            "reason": restart_reasons,
                            "result": _script("start_orderbook", env=env),
                        }
                    )
            else:
                actions.append({"kind": "dry_run", "reason": restart_reasons, "cmd": ["feeds/restart_orderbook"]})

    return {"actions": actions, "status": _build_status()}


def _print_human_status(st: dict[str, Any]) -> None:
    print(
        f"ts={st['ts_unix']} root={st['root_dir']} "
        f"pipeline_up={st.get('pipeline_up')} control_plane_up={st.get('control_plane_up')} healthy={st.get('healthy')}"
    )
    for svc in ("ingest", "orderbook", "supervise"):
        s = st["services"][svc]
        print(f"{svc}: up={s.get('up')} pidfile={s.get('pidfile_pid')} pids={s.get('live_pids', s.get('worker_pids', []))}")
    if st["anomalies"]:
        print("anomalies:")
        for a in st["anomalies"]:
            print(f"  - {a}")


def main() -> None:
    ap = argparse.ArgumentParser(description="Unified feed control plane")
    sub = ap.add_subparsers(dest="cmd", required=True)

    p_status = sub.add_parser("status", help="Show control-plane state")
    p_status.add_argument("--json", action="store_true", help="Emit JSON")

    p_rec = sub.add_parser("reconcile", help="Repair pidfiles/sockets and optional duplicate processes")
    p_rec.add_argument("--aggressive", action="store_true", help="Kill duplicate singleton processes")
    p_rec.add_argument("--json", action="store_true", help="Emit JSON")

    p_ens = sub.add_parser("ensure", help="Converge services to desired state")
    p_ens.add_argument("--ingest", choices=["up", "down", "keep"], default="up")
    p_ens.add_argument("--orderbook", choices=["up", "down", "keep"], default="up")
    p_ens.add_argument("--supervise", choices=["up", "down", "keep"], default="up")
    p_ens.add_argument("--workers", type=int, help="Desired OB worker count")
    p_ens.add_argument("--pin-cores", help="OB_PIN_CORES value (e.g. 14,15 or auto)")
    p_ens.add_argument("--ob-depth", type=int)
    p_ens.add_argument("--ob-period", type=int)
    p_ens.add_argument("--warmup-seconds", type=int)
    p_ens.add_argument("--ob-prefix")
    p_ens.add_argument("--ob-max-levels", type=int)
    p_ens.add_argument("--products")
    p_ens.add_argument("--base-path")
    p_ens.add_argument("--python")
    p_ens.add_argument("--dry-run", action="store_true")
    p_ens.add_argument("--reconcile", action="store_true", default=True)
    p_ens.add_argument("--no-reconcile", dest="reconcile", action="store_false")
    p_ens.add_argument("--aggressive", action="store_true")
    p_ens.add_argument("--json", action="store_true", help="Emit JSON")

    args = ap.parse_args()

    if args.cmd == "status":
        st = _build_status()
        if args.json:
            print(json.dumps(st, indent=2, sort_keys=True))
        else:
            _print_human_status(st)
        raise SystemExit(0 if st.get("healthy") else 1)

    if args.cmd == "reconcile":
        out = _reconcile(aggressive=args.aggressive)
        if args.json:
            print(json.dumps(out, indent=2, sort_keys=True))
        else:
            print(f"reconcile actions={len(out['actions'])}")
            for a in out["actions"]:
                print(a)
            _print_human_status(out["status"])
        raise SystemExit(0 if out["status"].get("healthy") else 1)

    if args.cmd == "ensure":
        out = _ensure(args)
        if args.json:
            print(json.dumps(out, indent=2, sort_keys=True))
        else:
            print(f"ensure actions={len(out['actions'])}")
            for a in out["actions"]:
                print(a)
            _print_human_status(out["status"])
        raise SystemExit(0 if out["status"].get("healthy") else 1)


if __name__ == "__main__":
    main()
