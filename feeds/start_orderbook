#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

DEFAULT_PRODUCTS="BTC-USD,BTC-USDT,ETH-USD,ETH-USDT,SOL-USD,SOL-USDT,USDT-USD,USDT-USDC,XRP-USD,XRP-USDT"
PRODUCTS="${PRODUCTS:-$DEFAULT_PRODUCTS}"
DEFAULT_BASE_PATH="$ROOT_DIR/data/coinbase-main"
if [ -d "/deepwater/data" ]; then
  DEFAULT_BASE_PATH="/deepwater/data/coinbase-advanced"
fi
BASE_PATH="${BASE_PATH:-$DEFAULT_BASE_PATH}"
OB_DEPTH="${OB_DEPTH:-256}"
OB_PERIOD="${OB_PERIOD:-100}"
WARMUP_SECONDS="${WARMUP_SECONDS:-60}"
OB_PREFIX="${OB_PREFIX:-OB}"
OB_MAX_LEVELS="${OB_MAX_LEVELS:-8192}"
OB_WORKERS="${OB_WORKERS:-2}"
OB_PIN_CORES="${OB_PIN_CORES:-auto}"

PY="${PY:-$ROOT_DIR/venv/bin/python}"
if [ ! -x "$PY" ]; then
  PY="python3"
fi

LOG_DIR="$SCRIPT_DIR/logs"
PID_DIR="$SCRIPT_DIR/pids"
INGEST_SOCK="$PID_DIR/ingest.sock"
ORDERBOOK_SOCK="$PID_DIR/orderbook.sock"
PIDFILE="$PID_DIR/orderbook.pid"

mkdir -p "$LOG_DIR" "$PID_DIR" "$BASE_PATH"
cd "$ROOT_DIR"

# If ingest is live, prefer its current product set so OB restarts track live subscriptions.
if [ -S "$INGEST_SOCK" ]; then
  live_products="$("$PY" "$SCRIPT_DIR/ingest_ctl.py" list 2>/dev/null || true)"
  if [ -n "$live_products" ] && [ "$live_products" != "ERR unknown" ]; then
    PRODUCTS="$live_products"
  fi
fi

if [ -z "$PRODUCTS" ]; then
  echo "orderbook start failed: empty product set"
  exit 1
fi

if [ -f "$PIDFILE" ]; then
  pid="$(cat "$PIDFILE")"
  if kill -0 "$pid" 2>/dev/null; then
    echo "orderbook already running pid=$pid"
    exit 1
  fi
  rm -f "$PIDFILE"
fi

if [ "$OB_WORKERS" = "1" ]; then
  echo "starting orderbook daemon"
  PYTHONPATH="$ROOT_DIR" nohup "$PY" "$SCRIPT_DIR/orderbook_daemon.py" \
    --products "$PRODUCTS" \
    --base-path "$BASE_PATH" \
    --depth "$OB_DEPTH" \
    --period "$OB_PERIOD" \
    --warmup-seconds "$WARMUP_SECONDS" \
    --feed-prefix "$OB_PREFIX" \
    --max-levels "$OB_MAX_LEVELS" \
    --control-sock "$ORDERBOOK_SOCK" \
    > "$LOG_DIR/orderbook.log" 2>&1 &
else
  if [ "$OB_WORKERS" = "0" ]; then
    echo "starting orderbook manager workers=auto"
  else
    echo "starting orderbook manager workers=$OB_WORKERS"
  fi
  PRODUCTS="$PRODUCTS" BASE_PATH="$BASE_PATH" OB_DEPTH="$OB_DEPTH" OB_PERIOD="$OB_PERIOD" \
  WARMUP_SECONDS="$WARMUP_SECONDS" OB_PREFIX="$OB_PREFIX" OB_MAX_LEVELS="$OB_MAX_LEVELS" OB_WORKERS="$OB_WORKERS" OB_PIN_CORES="$OB_PIN_CORES" PY="$PY" \
    nohup "$SCRIPT_DIR/orderbook_manager" > "$LOG_DIR/orderbook.log" 2>&1 &
fi
echo $! > "$PIDFILE"
echo "  orderbook_pid=$(cat "$PIDFILE")"

sleep 1
if ! kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "orderbook failed, see $LOG_DIR/orderbook.log"
  exit 1
fi
