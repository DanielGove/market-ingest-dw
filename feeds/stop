#!/usr/bin/env bash
# Stop pipeline processes.
# Usage:
#   ./feeds/stop                 # stop all
#   ./feeds/stop orderbook       # stop only orderbook daemons
#   ./feeds/stop ingest          # stop only ingest daemon
#   ./feeds/stop supervise       # stop only supervisor
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PID_DIR="$SCRIPT_DIR/pids"

usage() {
  cat <<'EOF'
Usage: ./feeds/stop [all|ingest|orderbook|supervise]...
If omitted, defaults to "orderbook" (ingest-safe).
EOF
}

is_valid_target() {
  case "$1" in
    all|ingest|orderbook|supervise) return 0 ;;
    *) return 1 ;;
  esac
}

pid_matches_service() {
  local service="$1"
  local pid="$2"
  local cmd
  cmd="$(ps -p "$pid" -o args= 2>/dev/null || true)"
  case "$service" in
    ingest) [[ "$cmd" == *"ws_ingest_daemon.py"* ]] ;;
    orderbook) [[ "$cmd" == *"orderbook_daemon.py"* || "$cmd" == *"/feeds/orderbook_manager"* ]] ;;
    supervise) [[ "$cmd" == *"/feeds/supervise"* ]] ;;
    *) return 1 ;;
  esac
}

collect_pidfiles() {
  local target="$1"
  local -n out_ref="$2"
  shopt -s nullglob
  case "$target" in
    all)
      for p in "$PID_DIR"/*.pid; do out_ref+=("$p"); done
      ;;
    ingest)
      for p in "$PID_DIR"/ingest*.pid; do out_ref+=("$p"); done
      ;;
    orderbook)
      for p in "$PID_DIR"/orderbook*.pid; do out_ref+=("$p"); done
      ;;
    supervise)
      for p in "$PID_DIR"/supervise*.pid; do out_ref+=("$p"); done
      ;;
  esac
  shopt -u nullglob
}

stop_pidfile() {
  local pidfile="$1"
  local name pid service
  name="$(basename "$pidfile" .pid)"
  pid="$(cat "$pidfile" 2>/dev/null || true)"

  if [[ "$name" == ingest* ]]; then
    service="ingest"
  elif [[ "$name" == orderbook* ]]; then
    service="orderbook"
  elif [[ "$name" == supervise* ]]; then
    service="supervise"
  else
    service=""
  fi

  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    if [ -n "$service" ] && ! pid_matches_service "$service" "$pid"; then
      echo "  skip $name pid=$pid (pid no longer matches $service)"
      rm -f "$pidfile"
      return
    fi
    echo "  stopping $name pid=$pid"
    kill "$pid" || true
    for _ in {1..10}; do
      if ! kill -0 "$pid" 2>/dev/null; then
        break
      fi
      sleep 0.2
    done
    if kill -0 "$pid" 2>/dev/null; then
      echo "  force stopping $name pid=$pid"
      kill -9 "$pid" || true
    fi
  fi
  rm -f "$pidfile"
}

targets=("$@")
if [ "${#targets[@]}" -eq 0 ]; then
  targets=("orderbook")
  echo "no target provided; defaulting to orderbook (ingest preserved)"
  echo "use './feeds/stop all' for full pipeline stop"
fi
for t in "${targets[@]}"; do
  if ! is_valid_target "$t"; then
    usage
    echo "invalid target: $t" >&2
    exit 1
  fi
done

if printf '%s\n' "${targets[@]}" | rg -qx 'all'; then
  targets=("all")
fi

echo "stopping coinbase data pipeline: ${targets[*]}"

pidfiles=()
for t in "${targets[@]}"; do
  collect_pidfiles "$t" pidfiles
done

declare -A seen=()
unique_pidfiles=()
for p in "${pidfiles[@]}"; do
  if [ -z "${seen[$p]:-}" ]; then
    seen[$p]=1
    unique_pidfiles+=("$p")
  fi
done

for p in "${unique_pidfiles[@]}"; do
  stop_pidfile "$p"
done

for t in "${targets[@]}"; do
  case "$t" in
    all)
      rm -f "$PID_DIR"/*.sock
      ;;
    ingest)
      rm -f "$PID_DIR"/ingest*.sock
      ;;
    orderbook)
      rm -f "$PID_DIR"/orderbook*.sock
      ;;
  esac
done

echo "stopped"
