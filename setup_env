#!/usr/bin/env bash
# One-time setup for coinbase-dw on a fresh clone.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

echo "==> Ensuring virtualenv"
if [ ! -d venv ]; then
  python3 -m venv venv
fi

echo "==> Installing requirements"
./venv/bin/pip install --upgrade pip >/dev/null
./venv/bin/pip install -r requirements.txt

echo "==> Marking helper scripts executable"
scripts=(
  setup_env
  tools/feed_health
  feeds/run
  feeds/stop
  feeds/status
  feeds/start_ingest
  feeds/start_orderbook
  feeds/start_ob
  feeds/restart_orderbook
  feeds/start_24x7
  feeds/supervise
  feeds/venue
  feeds/orderbook_manager
  feeds/ingest_ctl.py
  feeds/ob_ctl.py
  feeds/segment_ctl.py
  feeds/ws_ingest_daemon.py
  feeds/orderbook_daemon.py
)

for script in "${scripts[@]}"; do
  if [ -e "$script" ]; then
    chmod +x "$script"
  fi
done

echo "==> Done. Start pipeline with:"
echo "    ./feeds/run"
echo "  Control sockets (after feeds/run):"
echo "    ./feeds/ingest_ctl.py SUB BTC-USD"
echo "    ./feeds/ob_ctl.py ADD BTC-USD 200 200"
