#!/usr/bin/env bash
# One-time setup for market-ingest-dw on a fresh clone.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

echo "==> Ensuring virtualenv"
if [ ! -d venv ]; then
  python3 -m venv venv
fi

if [ ! -x ./venv/bin/python ]; then
  echo "venv exists but python executable is missing; recreating venv" >&2
  rm -rf ./venv
  python3 -m venv venv
fi

echo "==> Refreshing venv launchers"
./venv/bin/python -m ensurepip --upgrade >/dev/null
./venv/bin/python -m pip install --upgrade pip >/dev/null

echo "==> Installing requirements"
./venv/bin/python -m pip install -r requirements.txt

echo "==> Marking helper scripts executable"
scripts=(
  setup_env
  ops/feed_health
  ops/ingest_ctl
  ops/stop
  ops/status
  ops/deploy
  ops/ctl
  ops/discover
  ops/segment_health
  ops/internal/start_ingest
  ops/internal/start_24x7
  ops/internal/supervise
  ops/internal/venue_profile
  ops/internal/ws_ingest_daemon
)

for script in "${scripts[@]}"; do
  if [ -e "$script" ]; then
    chmod +x "$script"
  fi
done

echo "==> Done. Start pipeline with:"
echo "    ./ops/deploy coinbase --status --health"
echo "    ./ops/deploy kraken --status --health"
echo "    ./ops/deploy hyperliquid --status --health"
echo "  Control sockets (after ops/deploy ...):"
echo "    ./ops/ingest_ctl sub BTC-USD"
