#!/usr/bin/env bash
# Stop ingest runtime processes.
# Usage:
#   ./ops/stop [targets] [--instance <name>] [--all-instances]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PID_DIR="$SCRIPT_DIR/pids"

INSTANCE_RAW="${DW_INSTANCE:-${DW_VENUE:-default}}"
ALL_INSTANCES=0

sanitize_instance() {
  local raw="$1"
  local s
  s="$(printf '%s' "$raw" | tr -c '[:alnum:]_-' '_')"
  if [ -z "$s" ]; then
    s="default"
  fi
  echo "$s"
}

usage() {
  cat <<'EOF'
Usage: ./ops/stop [all|ingest|supervise]... [--instance <name>] [--all-instances]
If no target is provided, defaults to "all".
EOF
}

is_valid_target() {
  case "$1" in
    all|ingest|supervise) return 0 ;;
    *) return 1 ;;
  esac
}

pid_matches_service() {
  local service="$1"
  local pid="$2"
  local cmd
  cmd="$(ps -p "$pid" -o args= 2>/dev/null || true)"
  case "$service" in
    ingest) [[ "$cmd" == *"runtime/ws_ingest_daemon.py"* || "$cmd" == *"/ops/internal/ws_ingest_daemon"* ]] ;;
    supervise) [[ "$cmd" == *"/ops/internal/supervise"* ]] ;;
    *) return 1 ;;
  esac
}

collect_pidfiles() {
  local target="$1"
  local instance="$2"
  local all_instances="$3"
  local -n out_ref="$4"
  local pattern
  shopt -s nullglob
  case "$target" in
    all)
      if [ "$all_instances" -eq 1 ]; then
        for p in "$PID_DIR"/*.pid; do out_ref+=("$p"); done
      else
        for p in "$PID_DIR"/*."$instance".pid; do out_ref+=("$p"); done
      fi
      ;;
    ingest)
      if [ "$all_instances" -eq 1 ]; then
        pattern="$PID_DIR"/ingest*.pid
      else
        pattern="$PID_DIR"/ingest."$instance".pid
      fi
      for p in $pattern; do out_ref+=("$p"); done
      ;;
    supervise)
      if [ "$all_instances" -eq 1 ]; then
        pattern="$PID_DIR"/supervise*.pid
      else
        pattern="$PID_DIR"/supervise."$instance".pid
      fi
      for p in $pattern; do out_ref+=("$p"); done
      ;;
  esac
  shopt -u nullglob
}

kill_orphans_by_pattern() {
  local pattern="$1"
  local pids pid
  pids="$(pgrep -f "$pattern" || true)"
  if [ -z "$pids" ]; then
    return
  fi

  for pid in $pids; do
    if kill -0 "$pid" 2>/dev/null; then
      echo "  stopping orphan pid=$pid ($pattern)"
      kill "$pid" 2>/dev/null || true
    fi
  done

  sleep 0.2
  for pid in $pids; do
    if kill -0 "$pid" 2>/dev/null; then
      echo "  force stopping orphan pid=$pid ($pattern)"
      kill -9 "$pid" 2>/dev/null || true
    fi
  done
}

stop_pidfile() {
  local pidfile="$1"
  local name pid service
  name="$(basename "$pidfile" .pid)"
  pid="$(cat "$pidfile" 2>/dev/null || true)"

  if [[ "$name" == ingest* ]]; then
    service="ingest"
  elif [[ "$name" == supervise* ]]; then
    service="supervise"
  else
    service=""
  fi

  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    if [ -n "$service" ] && ! pid_matches_service "$service" "$pid"; then
      echo "  skip $name pid=$pid (pid no longer matches $service)"
      rm -f "$pidfile"
      return
    fi
    echo "  stopping $name pid=$pid"
    kill "$pid" || true
    for _ in {1..10}; do
      if ! kill -0 "$pid" 2>/dev/null; then
        break
      fi
      sleep 0.2
    done
    if kill -0 "$pid" 2>/dev/null; then
      echo "  force stopping $name pid=$pid"
      kill -9 "$pid" || true
    fi
  fi
  rm -f "$pidfile"
}

targets=()
while [ $# -gt 0 ]; do
  case "$1" in
    --instance)
      INSTANCE_RAW="${2:-}"
      shift 2
      ;;
    --all-instances)
      ALL_INSTANCES=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      targets+=("$1")
      shift
      ;;
  esac
done

INSTANCE="$(sanitize_instance "$INSTANCE_RAW")"

if [ "${#targets[@]}" -eq 0 ]; then
  targets=("all")
fi
for t in "${targets[@]}"; do
  if ! is_valid_target "$t"; then
    usage
    echo "invalid target: $t" >&2
    exit 1
  fi
done

for t in "${targets[@]}"; do
  if [ "$t" = "all" ]; then
    targets=("all")
    break
  fi
done

need_ingest=0
need_supervise=0
for t in "${targets[@]}"; do
  case "$t" in
    all)
      need_ingest=1
      need_supervise=1
      ;;
    ingest) need_ingest=1 ;;
    supervise) need_supervise=1 ;;
  esac
done

echo "stopping data pipeline: ${targets[*]}"
if [ "$ALL_INSTANCES" -eq 1 ]; then
  echo "  scope=all-instances"
else
  echo "  scope=instance:$INSTANCE"
fi

pidfiles=()
for t in "${targets[@]}"; do
  collect_pidfiles "$t" "$INSTANCE" "$ALL_INSTANCES" pidfiles
done

declare -A seen=()
unique_pidfiles=()
for p in "${pidfiles[@]}"; do
  if [ -z "${seen[$p]:-}" ]; then
    seen[$p]=1
    unique_pidfiles+=("$p")
  fi
done

for p in "${unique_pidfiles[@]}"; do
  stop_pidfile "$p"
done

if [ "$ALL_INSTANCES" -eq 1 ]; then
  if [ "$need_ingest" -eq 1 ]; then
    kill_orphans_by_pattern "$ROOT_DIR/runtime/ws_ingest_daemon.py"
  fi
  if [ "$need_supervise" -eq 1 ]; then
    kill_orphans_by_pattern "$ROOT_DIR/ops/internal/supervise"
  fi
else
  if [ "$need_ingest" -eq 1 ]; then
    kill_orphans_by_pattern "$PID_DIR/ingest.$INSTANCE.sock"
  fi
  if [ "$need_supervise" -eq 1 ]; then
    kill_orphans_by_pattern "$ROOT_DIR/ops/internal/supervise --instance $INSTANCE"
  fi
fi

for t in "${targets[@]}"; do
  case "$t" in
    all)
      if [ "$ALL_INSTANCES" -eq 1 ]; then
        rm -f "$PID_DIR"/*.sock
      else
        rm -f "$PID_DIR"/*."$INSTANCE".sock
      fi
      ;;
    ingest)
      if [ "$ALL_INSTANCES" -eq 1 ]; then
        rm -f "$PID_DIR"/ingest*.sock
      else
        rm -f "$PID_DIR"/ingest."$INSTANCE".sock
      fi
      ;;
  esac
done

echo "stopped"
