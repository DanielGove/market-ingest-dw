#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPS_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ROOT_DIR="$(cd "$OPS_DIR/.." && pwd)"
INSTANCE_RAW="${DW_INSTANCE:-${DW_VENUE_KEY:-${DW_VENUE:-default}}}"
INSTANCE="$(printf '%s' "$INSTANCE_RAW" | tr -c '[:alnum:]_-' '_')"
if [ -z "$INSTANCE" ]; then
  INSTANCE="default"
fi
VENUE_KEY="${DW_VENUE_KEY:-${DW_VENUE:-$INSTANCE}}"
PY="${PY:-$ROOT_DIR/venv/bin/python}"
if [ ! -x "$PY" ]; then
  PY="python3"
fi
if ! venue_env="$(PYTHONPATH="$ROOT_DIR" "$OPS_DIR/internal/venue_profile" --venue "$VENUE_KEY" --format shell --root-dir "$ROOT_DIR" 2>/dev/null)"; then
  echo "start_ingest: unknown venue '$VENUE_KEY' for instance '$INSTANCE'" >&2
  echo "set DW_VENUE or DW_VENUE_KEY explicitly to a discoverable connector venue" >&2
  exit 2
fi
eval "$venue_env"

PRODUCTS="${PRODUCTS:-$PRODUCTS_DEFAULT}"
BASE_PATH="${BASE_PATH:-$DEFAULT_BASE_PATH}"
URI="${URI:-}"
BOOK_DEPTH="${BOOK_DEPTH:-}"
INGEST_PIN_CPUS="${INGEST_PIN_CPUS:-}"

LOG_DIR="$OPS_DIR/logs"
PID_DIR="$OPS_DIR/pids"
INGEST_SOCK="$PID_DIR/ingest.$INSTANCE.sock"
PIDFILE="$PID_DIR/ingest.$INSTANCE.pid"
LOG_FILE="$LOG_DIR/ingest.$INSTANCE.log"

mkdir -p "$LOG_DIR" "$PID_DIR" "$BASE_PATH"
cd "$ROOT_DIR"

if [ -f "$PIDFILE" ]; then
  pid="$(cat "$PIDFILE")"
  if kill -0 "$pid" 2>/dev/null; then
    echo "ingest already running pid=$pid"
    exit 1
  fi
  rm -f "$PIDFILE"
fi

echo "starting l2 ingest"
echo "==== ingest launch $(date -u +%Y-%m-%dT%H:%M:%SZ) instance=$INSTANCE venue=$VENUE_KEY products=$PRODUCTS base_path=$BASE_PATH ====" >> "$LOG_FILE"
INGEST_ARGS=(
  --venue "$VENUE_KEY"
  --products "$PRODUCTS"
  --base-path "$BASE_PATH"
  --control-sock "$INGEST_SOCK"
)
if [ -n "$URI" ]; then
  INGEST_ARGS+=(--uri "$URI")
fi
if [ -n "$BOOK_DEPTH" ]; then
  INGEST_ARGS+=(--book-depth "$BOOK_DEPTH")
fi

LAUNCH_CMD=("$SCRIPT_DIR/ws_ingest_daemon" "${INGEST_ARGS[@]}")
if [ -n "$INGEST_PIN_CPUS" ]; then
  if command -v taskset >/dev/null 2>&1; then
    echo "  pin_cpus=$INGEST_PIN_CPUS"
    LAUNCH_CMD=(taskset -c "$INGEST_PIN_CPUS" "${LAUNCH_CMD[@]}")
  else
    echo "  pin_cpus requested but taskset unavailable; continuing unpinned"
  fi
fi

PYTHONPATH="$ROOT_DIR" DW_INSTANCE="$INSTANCE" nohup "${LAUNCH_CMD[@]}" >> "$LOG_FILE" 2>&1 &
echo $! > "$PIDFILE"
echo "  instance=$INSTANCE ingest_pid=$(cat "$PIDFILE") sock=$INGEST_SOCK"

sleep 1
if ! kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "ingest failed, see $LOG_FILE"
  exit 1
fi
