#!/usr/bin/env python3
"""Unified ingest control plane (human + automation friendly)."""

from __future__ import annotations

import argparse
import json
import os
import socket
import subprocess
import time
from pathlib import Path
from typing import Any


SCRIPT_PATH = Path(__file__).resolve()
OPS_DIR = SCRIPT_PATH.parent
ROOT_DIR = OPS_DIR.parent
PIDS_DIR = OPS_DIR / "pids"


def _instance_token(raw: str | None) -> str:
    text = (raw or "").strip()
    if not text:
        text = os.environ.get("DW_INSTANCE") or os.environ.get("DW_VENUE") or "default"
    out = "".join(ch if (ch.isalnum() or ch in "_-") else "_" for ch in text)
    return out or "default"


def _paths(instance: str) -> dict[str, Path]:
    return {
        "ingest_pidfile": PIDS_DIR / f"ingest.{instance}.pid",
        "supervise_pidfile": PIDS_DIR / f"supervise.{instance}.pid",
        "ingest_sock": PIDS_DIR / f"ingest.{instance}.sock",
    }


def _run(cmd: list[str], env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    merged_env = os.environ.copy()
    if env:
        merged_env.update({k: str(v) for k, v in env.items() if v is not None})
    return subprocess.run(
        cmd,
        cwd=str(ROOT_DIR),
        env=merged_env,
        text=True,
        capture_output=True,
    )


def _script(name: str, args: list[str] | None = None, env: dict[str, str] | None = None) -> dict[str, Any]:
    args = args or []
    cp = _run([str(OPS_DIR / name)] + args, env=env)
    return {
        "cmd": [name] + args,
        "rc": cp.returncode,
        "stdout": cp.stdout.strip(),
        "stderr": cp.stderr.strip(),
    }


def _alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def _read_pidfile(path: Path) -> int | None:
    try:
        return int(path.read_text(encoding="utf-8").strip())
    except Exception:
        return None


def _write_pidfile(path: Path, pid: int) -> None:
    path.write_text(f"{pid}\n", encoding="utf-8")


def _connect_cmd(sock_path: Path, cmd: str, timeout: float = 0.25) -> str | None:
    if not sock_path.exists():
        return None
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        s.settimeout(timeout)
        s.connect(str(sock_path))
        s.sendall((cmd + "\n").encode("ascii", "ignore"))
        data = s.recv(4096)
        return data.decode("ascii", "ignore").strip()
    except Exception:
        return None
    finally:
        try:
            s.close()
        except Exception:
            pass


def _proc_pids_containing(needle: str) -> list[int]:
    cp = _run(["ps", "-eo", "pid,args"])
    if cp.returncode != 0:
        return []
    out: list[int] = []
    for line in cp.stdout.splitlines()[1:]:
        line = line.strip()
        if not line or needle not in line:
            continue
        parts = line.split(maxsplit=1)
        if len(parts) != 2:
            continue
        try:
            out.append(int(parts[0]))
        except ValueError:
            continue
    return out


def _ingest_status(instance: str) -> dict[str, Any]:
    p = _paths(instance)
    ingest_pidfile = p["ingest_pidfile"]
    supervise_pidfile = p["supervise_pidfile"]
    ingest_sock = p["ingest_sock"]

    ingest_pid = _read_pidfile(ingest_pidfile)
    supervise_pid = _read_pidfile(supervise_pidfile)

    ingest_up = bool(ingest_pid and _alive(ingest_pid))
    supervise_up = bool(supervise_pid and _alive(supervise_pid))

    ingest_list_raw = _connect_cmd(ingest_sock, "LIST")
    ingest_status_raw = _connect_cmd(ingest_sock, "STATUS")

    runtime: dict[str, Any] = {}
    if ingest_status_raw:
        try:
            runtime = json.loads(ingest_status_raw)
        except Exception:
            runtime = {}

    products: list[str] = []
    if ingest_list_raw:
        products = [x.strip().upper() for x in ingest_list_raw.split(",") if x.strip()]
    elif isinstance(runtime.get("subs"), list):
        products = [str(x).upper() for x in runtime.get("subs", []) if str(x).strip()]

    ingest_live = _proc_pids_containing(str(ingest_sock))
    if ingest_up and ingest_pid and ingest_pid not in ingest_live:
        ingest_live = [ingest_pid] + ingest_live
    supervise_live = [supervise_pid] if supervise_up and supervise_pid else []

    anomalies: list[str] = []
    if len(ingest_live) > 1:
        anomalies.append("duplicate ingest processes")
    if len(supervise_live) > 1:
        anomalies.append("duplicate supervise processes")
    if ingest_up and not runtime and ingest_list_raw is None:
        anomalies.append("ingest socket unresponsive")

    healthy = ingest_up and (not anomalies)

    return {
        "ts_unix": int(time.time()),
        "root_dir": str(ROOT_DIR),
        "instance": instance,
        "services": {
            "ingest": {
                "up": ingest_up,
                "pidfile": str(ingest_pidfile),
                "pidfile_pid": ingest_pid,
                "live_pids": ingest_live,
                "socket": str(ingest_sock),
                "socket_healthy": ingest_list_raw is not None or bool(runtime),
                "products": products,
                "runtime": runtime,
            },
            "supervise": {
                "up": supervise_up,
                "pidfile": str(supervise_pidfile),
                "pidfile_pid": supervise_pid,
                "live_pids": supervise_live,
            },
        },
        "anomalies": anomalies,
        "pipeline_up": ingest_up,
        "control_plane_up": supervise_up,
        "healthy": healthy,
    }


def _reconcile(instance: str, aggressive: bool = False) -> dict[str, Any]:
    actions: list[dict[str, Any]] = []
    st = _ingest_status(instance)

    for service in ("ingest", "supervise"):
        info = st["services"][service]
        pidfile = Path(info["pidfile"])
        pidfile_pid = info.get("pidfile_pid")
        live_pids = info.get("live_pids", [])

        if pidfile_pid is not None and pidfile_pid not in live_pids and not _alive(pidfile_pid):
            pidfile.unlink(missing_ok=True)
            actions.append({"kind": "pidfile_remove", "service": service, "pid": pidfile_pid})

        if (pidfile_pid is None or pidfile_pid not in live_pids) and len(live_pids) == 1:
            _write_pidfile(pidfile, int(live_pids[0]))
            actions.append({"kind": "pidfile_write", "service": service, "pid": int(live_pids[0])})

    ingest_sock = Path(st["services"]["ingest"]["socket"])
    if ingest_sock.exists() and not st["services"]["ingest"]["up"]:
        ingest_sock.unlink(missing_ok=True)
        actions.append({"kind": "socket_remove", "socket": str(ingest_sock)})

    if aggressive:
        for service in ("ingest", "supervise"):
            info = st["services"][service]
            live_pids = list(info.get("live_pids", []))
            keep = info.get("pidfile_pid") if info.get("pidfile_pid") in live_pids else (live_pids[0] if live_pids else None)
            for pid in live_pids:
                if keep is not None and pid == keep:
                    continue
                try:
                    os.kill(pid, 15)
                    time.sleep(0.1)
                    if _alive(pid):
                        os.kill(pid, 9)
                    actions.append({"kind": "kill_duplicate", "service": service, "pid": pid})
                except Exception as exc:
                    actions.append({"kind": "error", "service": service, "pid": pid, "error": str(exc)})

    return {"actions": actions, "status": _ingest_status(instance)}


def _apply_env_from_args(args: argparse.Namespace) -> dict[str, str]:
    env: dict[str, str] = {}
    env["DW_INSTANCE"] = str(_instance_token(getattr(args, "instance", None)))
    if args.products is not None:
        env["PRODUCTS"] = str(args.products)
    if args.base_path is not None:
        env["BASE_PATH"] = str(args.base_path)
    if args.python is not None:
        env["PY"] = str(args.python)
    if args.pin_cpus is not None:
        env["INGEST_PIN_CPUS"] = str(args.pin_cpus)
    return env


def _ensure(args: argparse.Namespace) -> dict[str, Any]:
    instance = _instance_token(args.instance)
    actions: list[dict[str, Any]] = []

    if args.reconcile:
        rec = _reconcile(instance, aggressive=args.aggressive)
        actions.extend(rec["actions"])

    env = _apply_env_from_args(args)
    st = _ingest_status(instance)

    if args.supervise == "up" and not st["services"]["supervise"]["up"]:
        actions.append({
            "kind": "exec",
            "result": _script("internal/start_24x7", ["--instance", instance], env=env),
        })
    elif args.supervise == "down" and st["services"]["supervise"]["up"]:
        actions.append({
            "kind": "exec",
            "result": _script("stop", ["supervise", "--instance", instance], env=env),
        })

    st = _ingest_status(instance)
    if args.ingest == "up" and not st["services"]["ingest"]["up"]:
        actions.append({"kind": "exec", "result": _script("internal/start_ingest", env=env)})
    elif args.ingest == "down" and st["services"]["ingest"]["up"]:
        actions.append({
            "kind": "exec",
            "result": _script("stop", ["ingest", "--instance", instance], env=env),
        })

    return {"actions": actions, "status": _ingest_status(instance)}


def _print_human_status(st: dict[str, Any]) -> None:
    print(
        f"ts={st['ts_unix']} root={st['root_dir']} instance={st['instance']} "
        f"pipeline_up={st.get('pipeline_up')} control_plane_up={st.get('control_plane_up')} healthy={st.get('healthy')}"
    )
    for svc in ("ingest", "supervise"):
        s = st["services"][svc]
        print(f"{svc}: up={s.get('up')} pidfile={s.get('pidfile_pid')} pids={s.get('live_pids', [])}")
    if st["anomalies"]:
        print("anomalies:")
        for a in st["anomalies"]:
            print(f"  - {a}")


def main() -> None:
    ap = argparse.ArgumentParser(description="Unified ingest control plane")
    sub = ap.add_subparsers(dest="cmd", required=True)

    p_status = sub.add_parser("status", help="Show control-plane state")
    p_status.add_argument("--instance", default=None, help="Runtime instance name")
    p_status.add_argument("--json", action="store_true", help="Emit JSON")

    p_rec = sub.add_parser("reconcile", help="Repair pidfiles/sockets and optional duplicate processes")
    p_rec.add_argument("--instance", default=None, help="Runtime instance name")
    p_rec.add_argument("--aggressive", action="store_true", help="Kill duplicate singleton processes")
    p_rec.add_argument("--json", action="store_true", help="Emit JSON")

    p_ens = sub.add_parser("ensure", help="Converge services to desired state")
    p_ens.add_argument("--instance", default=None, help="Runtime instance name")
    p_ens.add_argument("--ingest", choices=["up", "down", "keep"], default="up")
    p_ens.add_argument("--supervise", choices=["up", "down", "keep"], default="up")
    p_ens.add_argument("--products")
    p_ens.add_argument("--base-path")
    p_ens.add_argument("--pin-cpus", help="Pin ingest process to CPU set (taskset format)")
    p_ens.add_argument("--python")
    p_ens.add_argument("--reconcile", action="store_true", default=True)
    p_ens.add_argument("--no-reconcile", dest="reconcile", action="store_false")
    p_ens.add_argument("--aggressive", action="store_true")
    p_ens.add_argument("--json", action="store_true", help="Emit JSON")

    args = ap.parse_args()
    instance = _instance_token(getattr(args, "instance", None))

    if args.cmd == "status":
        st = _ingest_status(instance)
        if args.json:
            print(json.dumps(st, indent=2, sort_keys=True))
        else:
            _print_human_status(st)
        raise SystemExit(0 if st.get("healthy") else 1)

    if args.cmd == "reconcile":
        out = _reconcile(instance, aggressive=args.aggressive)
        if args.json:
            print(json.dumps(out, indent=2, sort_keys=True))
        else:
            print(f"reconcile actions={len(out['actions'])}")
            for a in out["actions"]:
                print(a)
            _print_human_status(out["status"])
        raise SystemExit(0 if out["status"].get("healthy") else 1)

    out = _ensure(args)
    if args.json:
        print(json.dumps(out, indent=2, sort_keys=True))
    else:
        print(f"ensure actions={len(out['actions'])}")
        for a in out["actions"]:
            print(a)
        _print_human_status(out["status"])
    raise SystemExit(0 if out["status"].get("healthy") else 1)


if __name__ == "__main__":
    main()
